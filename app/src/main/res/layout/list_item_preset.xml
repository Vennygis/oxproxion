<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/textPresetTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Preset Title"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Expand chevron -->
        <ImageView
            android:id="@+id/iconExpand"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/br_circle"
            android:contentDescription="Expand/collapse"
            android:padding="8dp"
            android:rotation="0"
            android:src="@drawable/ic_arrow_downward"
            app:tint="?android:attr/textColorSecondary" />

        <ImageView
            android:id="@+id/iconEditPreset"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/br_circle"
            android:contentDescription="Edit preset"
            android:padding="8dp"
            android:src="@drawable/ic_editnote"
            app:tint="?android:attr/textColorSecondary" />
    </LinearLayout>

    <!-- Collapsible container for preview details -->
    <LinearLayout
        android:id="@+id/containerPresetSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:id="@+id/textPresetSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Model • System Message • Flags"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Divider: Using colorOutline or colorOnSurface with low alpha for a clean look -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOutlineVariant" />

</LinearLayout>
