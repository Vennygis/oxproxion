<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="?attr/colorSurface">

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Model Name"
        app:boxStrokeColor="?attr/colorPrimary"
        app:hintTextColor="?attr/colorPrimary"
        android:textColorHint="?android:attr/textColorSecondary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editModelName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?android:attr/textColorPrimary"
            />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="API Identifier"
        android:layout_marginTop="8dp"
        app:boxStrokeColor="?attr/colorPrimary"
        app:hintTextColor="?attr/colorPrimary"
        android:textColorHint="?android:attr/textColorSecondary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editApiIdentifier"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?android:attr/textColorPrimary"
            />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switchVisionCapable"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Vision Capable"
        android:textColor="?android:attr/textColorPrimary"
        android:visibility="visible"
        />

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switchReasoningCapable"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Reasoning Capable"
        android:textColor="?android:attr/textColorPrimary"
        android:visibility="visible"
        />

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switchLanModel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="LAN Model"
        android:textColor="?android:attr/textColorPrimary" />

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switchImageGen"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Image Generation"
        android:textColor="?android:attr/textColorPrimary" />

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switchTranscription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Transcription"
        android:textColor="?android:attr/textColorPrimary" />

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switchIsFree"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Is Free Model"
        android:textColor="?android:attr/textColorPrimary" />

</LinearLayout>
