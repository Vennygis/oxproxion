<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageView
            android:id="@+id/iconModelType"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="16dp"
            app:srcCompat="@drawable/ic_vision"
            app:tint="?android:attr/textColorSecondary" />

        <!-- CLEANUP: Removed the nested LinearLayout. Just use the TextView directly -->
        <TextView
            android:id="@+id/textModelName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:gravity="center_vertical"
            tools:text="Model Name (e.g., GPT-4o)" />

        <!-- NEW: LAN / Cloud source network indicator icon -->
        <ImageView
            android:id="@+id/iconModelSource"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="16dp"
            android:contentDescription="Model source type"

            tools:src="@drawable/ic_lan2" />

        <ImageView
            android:id="@+id/iconEdit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:background="@drawable/br_gray"

            android:contentDescription="Edit model"
            android:padding="8dp"
            android:src="@drawable/ic_editnote"
            app:tint="?android:attr/textColorSecondary"
            android:foreground="?attr/selectableItemBackgroundBorderless" />

    </LinearLayout>

    <!-- Separator Line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="56dp"
        android:background="?attr/colorOutlineVariant" />

</LinearLayout>