<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Oxproxion" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">#000000</item>
        <item name="colorSurface">#000000</item>
        <item name="colorOnSurface">#C2C2C2</item> <item name="colorPrimary">#C2C2C2</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="android:textColorHighlight">#007541</item> <item name="colorControlActivated">@color/your_orange_color</item> <item name="colorControlNormal">#C2C2C2</item>
        <item name="android:colorControlNormal">#C2C2C2</item>
        <item name="colorOutline">#686868</item>
        <item name="colorSurfaceVariant">#121212</item>

        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:navigationBarColor">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <item name="materialAlertDialogTheme">@style/CustomMaterialAlertDialogTheme</item>
    </style>

    <style name="Widget.App.CheckBox" parent="Widget.Material3.CompoundButton.CheckBox">
        <item name="buttonTint">@color/button_tint</item>
        <item name="buttonIconTint">@color/button_icon_tint</item>
    </style>

    <style name="CustomMaterialAlertDialogTheme" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="android:backgroundDimAmount">0.8</item>
        <item name="shapeAppearanceMediumComponent">@style/ff</item>
        <item name="android:textColorPrimary">#C2C2C2</item>
        <item name="colorPrimary">#C2C2C2</item>
        <item name="materialAlertDialogTitleTextStyle">@style/CustomDialogTitleText</item>
        <item name="materialAlertDialogBodyTextStyle">@style/CustomDialogBodyText</item>
        <item name="android:colorAccent">@color/your_orange_color</item>
    </style>

    <style name="ff" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="CustomDialogTheme" parent="ThemeOverlay.Material3.Dialog.Alert">
        <item name="colorSurface">#471d0d</item>
        <item name="android:background">#471d0d</item>
        <item name="android:backgroundDimAmount">0.8</item>
        <item name="android:textColorPrimary">#C2C2C2</item>
        <item name="colorPrimary">#C2C2C2</item>
        <item name="materialAlertDialogTitleTextStyle">@style/CustomDialogTitleText</item>
        <item name="materialAlertDialogBodyTextStyle">@style/CustomDialogBodyText</item>
    </style>

    <style name="CustomDialogBodyText" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">#C2C2C2</item>
    </style>

    <style name="CustomDialogTitleText" parent="MaterialAlertDialog.Material3.Title.Text">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">#C2C2C2</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="RoundedCornersDialog" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="android:backgroundDimAmount">0.8</item>
        <item name="android:windowBackground">@drawable/rounded_dialog_background</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="colorAccent">#C2C2C2</item>
        <item name="colorPrimary">#C2C2C2</item>
    </style>

    <style name="MyEditTextTheme" parent="ThemeOverlay.AppCompat.Light">
        <item name="colorControlActivated">#FF9800</item>
        <item name="colorControlNormal">#79480a</item>
    </style>



    <style name="Theme.Oxproxion.AIFix" parent="Theme.Oxproxion">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.5</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.Dialog</item>
    </style>
</resources>